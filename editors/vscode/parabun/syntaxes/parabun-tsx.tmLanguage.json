{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Parabun TSX",
  "scopeName": "source.ptsx",
  "patterns": [
    {
      "include": "#parabun-fun"
    },
    {
      "include": "#parabun-pure"
    },
    {
      "include": "#parabun-operators"
    },
    {
      "include": "#parabun-parallel"
    },
    {
      "include": "#parabun-decimal-literal"
    },
    {
      "include": "source.tsx"
    }
  ],
  "repository": {
    "parabun-fun": {
      "patterns": [
        {
          "match": "\\b(fun)\\b(?=\\s*[a-zA-Z_$*(<])",
          "captures": {
            "1": {
              "name": "storage.type.function.tsx"
            }
          }
        }
      ]
    },
    "parabun-pure": {
      "patterns": [
        {
          "match": "\\b(export)\\s+(pure)\\s+(async)\\s+(fun(?:ction)?)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.export.tsx"
            },
            "2": {
              "name": "keyword.other.pure.parabun"
            },
            "3": {
              "name": "storage.modifier.async.tsx"
            },
            "4": {
              "name": "storage.type.function.tsx"
            }
          }
        },
        {
          "match": "\\b(export)\\s+(pure)\\s+(fun(?:ction)?)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.export.tsx"
            },
            "2": {
              "name": "keyword.other.pure.parabun"
            },
            "3": {
              "name": "storage.type.function.tsx"
            }
          }
        },
        {
          "match": "\\b(pure)\\s+(async)\\s+(fun(?:ction)?)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.pure.parabun"
            },
            "2": {
              "name": "storage.modifier.async.tsx"
            },
            "3": {
              "name": "storage.type.function.tsx"
            }
          }
        },
        {
          "match": "\\b(pure)\\s+(fun(?:ction)?)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.pure.parabun"
            },
            "2": {
              "name": "storage.type.function.tsx"
            }
          }
        },
        {
          "match": "\\b(pure)\\s+(async)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
          "captures": {
            "1": {
              "name": "keyword.other.pure.parabun"
            },
            "2": {
              "name": "storage.modifier.async.tsx"
            }
          }
        },
        {
          "match": "\\b(pure)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
          "captures": {
            "1": {
              "name": "keyword.other.pure.parabun"
            }
          }
        }
      ]
    },
    "parabun-operators": {
      "patterns": [
        {
          "name": "keyword.operator.range-inclusive.parabun",
          "match": "\\.\\.="
        },
        {
          "name": "keyword.operator.catch.parabun",
          "match": "\\.\\.!"
        },
        {
          "name": "keyword.operator.finally.parabun",
          "match": "\\.\\.&"
        },
        {
          "name": "keyword.operator.then.parabun",
          "match": "\\.\\.>"
        },
        {
          "name": "keyword.operator.range.parabun",
          "match": "\\.\\.(?!\\.)",
          "comment": "Bare `..` range \u2014 negative lookahead `(?!\\.)` so the pattern does not eat the first two dots of `...` (spread/rest), which would leave the trailing `.x` looking like member access. The `..=` / `..!` / `..&` / `..>` variants cannot collide because each carries its own third character."
        },
        {
          "name": "keyword.operator.pipeline.parabun",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.rbind.parabun",
          "match": "~>"
        },
        {
          "name": "keyword.operator.callbind.parabun",
          "match": "(?<![\\-=<])->"
        }
      ]
    },
    "parabun-parallel": {
      "patterns": [
        {
          "comment": "parallel let/const — statement form, fan-out promise composition",
          "match": "\\b(parallel)\\s+(let|const)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.parallel.parabun"
            },
            "2": {
              "name": "storage.type.tsx"
            }
          }
        },
        {
          "comment": "parallel { … } — expression form, fan-out promise composition",
          "match": "\\b(parallel)\\b(?=\\s*\\{)",
          "captures": {
            "1": {
              "name": "keyword.other.parallel.parabun"
            }
          }
        }
      ]
    },
    "parabun-decimal-literal": {
      "patterns": [
        {
          "comment": "Nd decimal literal — base-10 number followed by `d` suffix",
          "match": "(?<![\\w$.])((?:\\.\\d+|\\d+(?:\\.\\d*)?)(?:[eE][+-]?\\d+)?)(d)(?![\\w$])",
          "captures": {
            "1": {
              "name": "constant.numeric.decimal.parabun"
            },
            "2": {
              "name": "keyword.other.suffix.decimal.parabun"
            }
          }
        }
      ]
    }
  }
}
