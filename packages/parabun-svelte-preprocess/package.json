{
  "name": "parabun-svelte-preprocess",
  "version": "0.1.0",
  "description": "Svelte preprocessor that lets <script lang=\"parabun\"> blocks and imported .pts/.pjs modules use Parabun syntax (pure, ..!, ..&, ..=, |>)",
  "repository": {
    "type": "git",
    "url": "https://github.com/airgap/parabun",
    "directory": "packages/parabun-svelte-preprocess"
  },
  "license": "MIT",
  "type": "module",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "check:types": "tsc --noEmit",
    "build": "tsc"
  },
  "devDependencies": {
    "svelte": "^5.20.4",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "svelte": "^5"
  },
  "files": [
    "README.md",
    "src",
    "dist"
  ]
}
