{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Parabun JSX",
  "scopeName": "source.pjsx",
  "patterns": [
    {
      "include": "#parabun-is"
    },
    {
      "include": "#parabun-model"
    },
    {
      "include": "#parabun-match"
    },
    {
      "include": "#parabun-effect"
    },
    {
      "include": "#parabun-when"
    },
    {
      "include": "#parabun-arena"
    },
    {
      "include": "#parabun-signal"
    },
    {
      "include": "#parabun-validation-marker"
    },
    {
      "include": "#parabun-result-ctors"
    },
    {
      "include": "#parabun-builtin-types"
    },
    {
      "include": "#parabun-fun"
    },
    {
      "include": "#parabun-pure"
    },
    {
      "include": "#parabun-operators"
    },
    {
      "include": "#parabun-parallel"
    },
    {
      "include": "#parabun-decimal-literal"
    },
    {
      "include": "source.jsx"
    }
  ],
  "repository": {
    "parabun-model": {
      "patterns": [
        {
          "comment": "export model NAME from <expr> — ingest existing JSON Schema",
          "match": "\\b(export)\\s+(schema)\\s+([A-Za-z_$][\\w$]*)\\s+(from)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.export.jsx"
            },
            "2": {
              "name": "storage.type.model.parabun"
            },
            "3": {
              "name": "entity.name.type.model.parabun"
            },
            "4": {
              "name": "keyword.control.from.parabun"
            }
          }
        },
        {
          "comment": "model NAME from <expr> — ingest existing JSON Schema",
          "match": "\\b(schema)\\s+([A-Za-z_$][\\w$]*)\\s+(from)\\b",
          "captures": {
            "1": {
              "name": "storage.type.model.parabun"
            },
            "2": {
              "name": "entity.name.type.model.parabun"
            },
            "3": {
              "name": "keyword.control.from.parabun"
            }
          }
        },
        {
          "comment": "export model NAME { ... } — declaration",
          "match": "\\b(export)\\s+(schema)\\s+([A-Za-z_$][\\w$]*)\\b(?=\\s*\\{)",
          "captures": {
            "1": {
              "name": "keyword.control.export.jsx"
            },
            "2": {
              "name": "storage.type.model.parabun"
            },
            "3": {
              "name": "entity.name.type.model.parabun"
            }
          }
        },
        {
          "comment": "model NAME { ... } — declaration",
          "match": "\\b(schema)\\s+([A-Za-z_$][\\w$]*)\\b(?=\\s*\\{)",
          "captures": {
            "1": {
              "name": "storage.type.model.parabun"
            },
            "2": {
              "name": "entity.name.type.model.parabun"
            }
          }
        },
        {
          "comment": "schema { ... } — inline JSON Schema literal",
          "match": "\\b(schema)\\b(?=\\s*\\{)",
          "captures": {
            "1": {
              "name": "storage.type.model.parabun"
            }
          }
        }
      ]
    },
    "parabun-match": {
      "patterns": [
        {
          "comment": "match EXPR { ... } — pattern matching expression",
          "match": "\\b(match)\\b(?=\\s+[A-Za-z_$(])",
          "captures": {
            "1": {
              "name": "keyword.control.match.parabun"
            }
          }
        }
      ]
    },
    "parabun-effect": {
      "patterns": [
        {
          "comment": "effect { ... } — signal effect block",
          "match": "\\b(effect)\\b(?=\\s*\\{)",
          "captures": {
            "1": {
              "name": "keyword.control.effect.parabun"
            }
          }
        }
      ]
    },
    "parabun-when": {
      "patterns": [
        {
          "comment": "when not EXPR { ... } / when not { ... } (else)",
          "match": "\\b(when)\\s+(not)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.when.parabun"
            },
            "2": {
              "name": "keyword.control.when-not.parabun"
            }
          }
        },
        {
          "comment": "when EXPR { ... } — guarded block",
          "match": "\\b(when)\\b(?=\\s+[!A-Za-z_$(])",
          "captures": {
            "1": {
              "name": "keyword.control.when.parabun"
            }
          }
        }
      ]
    },
    "parabun-arena": {
      "patterns": [
        {
          "comment": "arena { ... } — DeferGC scope",
          "match": "\\b(arena)\\b(?=\\s*\\{)",
          "captures": {
            "1": {
              "name": "keyword.control.arena.parabun"
            }
          }
        }
      ]
    },
    "parabun-signal": {
      "patterns": [
        {
          "comment": "signal NAME = ... — reactive cell declaration",
          "match": "\\b(signal)\\s+([A-Za-z_$][\\w$]*)\\b",
          "captures": {
            "1": {
              "name": "storage.type.signal.parabun"
            },
            "2": {
              "name": "variable.other.signal.parabun"
            }
          }
        }
      ]
    },
    "parabun-validation-marker": {
      "patterns": [
        {
          "comment": ":: per-arg validation marker — `(req:: User)` runs User.parse at fn entry",
          "name": "keyword.operator.validate.parabun",
          "match": "::"
        }
      ]
    },
    "parabun-result-ctors": {
      "patterns": [
        {
          "comment": "Ok / Err / Some / None — Result/Option constructor application",
          "match": "\\b(Ok|Err|Some)\\b(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "support.function.constructor.result.parabun"
            }
          }
        },
        {
          "comment": "None — bare Option constant",
          "match": "\\b(None)\\b(?!\\s*[\\.\\[\\(])",
          "captures": {
            "1": {
              "name": "constant.language.option.none.parabun"
            }
          }
        }
      ]
    },
    "parabun-builtin-types": {
      "patterns": [
        {
          "comment": "Capitalized refinement / format types in model field positions",
          "match": "(:|::)(\\s+)(Email|UUID|Url|Date|DateTime|IpV4|IpV6|Slug)\\b",
          "captures": {
            "1": {
              "name": "punctuation.separator.key-value.ts"
            },
            "3": {
              "name": "support.type.ts"
            }
          }
        },
        {
          "comment": "Lowercase primitive types in model field positions",
          "match": "(:)(\\s+)(int|str|string|bool|boolean|float|num|number)\\b",
          "captures": {
            "1": {
              "name": "punctuation.separator.key-value.ts"
            },
            "3": {
              "name": "support.type.primitive.ts"
            }
          }
        }
      ]
    },
    "parabun-fun": {
      "patterns": [
        {
          "comment": "fun keyword (shorthand for function)",
          "match": "\\b(fun)\\b(?=\\s*[a-zA-Z_$*(<])",
          "captures": {
            "1": {
              "name": "storage.type.function.jsx"
            }
          }
        }
      ]
    },
    "parabun-pure": {
      "patterns": [
        {
          "comment": "export pure async fun/function",
          "match": "\\b(export)\\s+(pure)\\s+(async)\\s+(fun(?:ction)?)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.export.jsx"
            },
            "2": {
              "name": "keyword.other.pure.parabun"
            },
            "3": {
              "name": "storage.modifier.async.jsx"
            },
            "4": {
              "name": "storage.type.function.jsx"
            }
          }
        },
        {
          "comment": "export pure fun/function",
          "match": "\\b(export)\\s+(pure)\\s+(fun(?:ction)?)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.export.jsx"
            },
            "2": {
              "name": "keyword.other.pure.parabun"
            },
            "3": {
              "name": "storage.type.function.jsx"
            }
          }
        },
        {
          "comment": "pure async fun/function declaration/expression",
          "match": "\\b(pure)\\s+(async)\\s+(fun(?:ction)?)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.pure.parabun"
            },
            "2": {
              "name": "storage.modifier.async.jsx"
            },
            "3": {
              "name": "storage.type.function.jsx"
            }
          }
        },
        {
          "comment": "pure fun/function declaration/expression",
          "match": "\\b(pure)\\s+(fun(?:ction)?)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.pure.parabun"
            },
            "2": {
              "name": "storage.type.function.jsx"
            }
          }
        },
        {
          "comment": "pure async arrow (before async keyword)",
          "match": "\\b(pure)\\s+(async)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
          "captures": {
            "1": {
              "name": "keyword.other.pure.parabun"
            },
            "2": {
              "name": "storage.modifier.async.jsx"
            }
          }
        },
        {
          "comment": "pure arrow (before parens or identifier)",
          "match": "\\b(pure)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
          "captures": {
            "1": {
              "name": "keyword.other.pure.parabun"
            }
          }
        }
      ]
    },
    "parabun-operators": {
      "patterns": [
        {
          "comment": "..= inclusive-range operator",
          "name": "keyword.operator.range-inclusive.parabun",
          "match": "\\.\\.="
        },
        {
          "comment": "..! error catch operator",
          "name": "keyword.operator.catch.parabun",
          "match": "\\.\\.!"
        },
        {
          "comment": "..& finally operator",
          "name": "keyword.operator.finally.parabun",
          "match": "\\.\\.&"
        },
        {
          "comment": "..> then operator",
          "name": "keyword.operator.then.parabun",
          "match": "\\.\\.>"
        },
        {
          "comment": ".. exclusive-range operator (must come after ..= / ..! / ..& / ..>)",
          "name": "keyword.operator.range.parabun",
          "match": "\\.\\.(?!\\.)"
        },
        {
          "comment": "|> pipeline operator",
          "name": "keyword.operator.pipeline.parabun",
          "match": "\\|>"
        },
        {
          "comment": "~> reactive-binding operator",
          "name": "keyword.operator.rbind.parabun",
          "match": "~>"
        },
        {
          "comment": "-> reactive call-binding operator (negative lookbehind on -/=/< guards against -->/=>/<-)",
          "name": "keyword.operator.callbind.parabun",
          "match": "(?<![\\-=<])->"
        }
      ]
    },
    "parabun-parallel": {
      "patterns": [
        {
          "comment": "parallel/para let/const — statement form, fan-out promise composition",
          "match": "\\b(parallel|para)\\s+(let|const)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.parallel.parabun"
            },
            "2": {
              "name": "storage.type.jsx"
            }
          }
        },
        {
          "comment": "parallel/para { … } — expression form, fan-out promise composition",
          "match": "\\b(parallel|para)\\b(?=\\s*\\{)",
          "captures": {
            "1": {
              "name": "keyword.other.parallel.parabun"
            }
          }
        }
      ]
    },
    "parabun-decimal-literal": {
      "patterns": [
        {
          "comment": "Nd decimal literal — base-10 number followed by `d` suffix",
          "match": "(?<![\\w$.])((?:\\.\\d+|\\d+(?:\\.\\d*)?)(?:[eE][+-]?\\d+)?)(d)(?![\\w$])",
          "captures": {
            "1": {
              "name": "constant.numeric.decimal.parabun"
            },
            "2": {
              "name": "keyword.other.suffix.decimal.parabun"
            }
          }
        }
      ]
    },
    "parabun-is": {
      "patterns": [
        {
          "comment": "expr is not Type — runtime negated type-guard",
          "match": "\\b(is)\\s+(not)\\b(?=\\s+[A-Z])",
          "captures": {
            "1": {
              "name": "keyword.operator.is.parabun"
            },
            "2": {
              "name": "keyword.operator.is.parabun"
            }
          }
        },
        {
          "comment": "expr is Type — runtime type-guard, lowers to Type.parse(expr).tag === \"Ok\"",
          "match": "\\b(is)\\b(?=\\s+[A-Z])",
          "captures": {
            "1": {
              "name": "keyword.operator.is.parabun"
            }
          }
        }
      ]
    }
  }
}