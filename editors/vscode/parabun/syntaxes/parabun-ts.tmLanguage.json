{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Parabun TypeScript",
  "scopeName": "source.pts",
  "patterns": [
    {
      "include": "#parabun-fun"
    },
    {
      "include": "#parabun-pure"
    },
    {
      "include": "#parabun-operators"
    },
    {
      "include": "#parabun-parallel"
    },
    {
      "include": "#parabun-decimal-literal"
    },
    {
      "include": "source.ts"
    }
  ],
  "repository": {
    "parabun-fun": {
      "patterns": [
        {
          "comment": "fun keyword (shorthand for function)",
          "match": "\\b(fun)\\b(?=\\s*[a-zA-Z_$*(<])",
          "captures": {
            "1": {
              "name": "storage.type.function.ts"
            }
          }
        }
      ]
    },
    "parabun-pure": {
      "patterns": [
        {
          "comment": "export pure async fun/function",
          "match": "\\b(export)\\s+(pure)\\s+(async)\\s+(fun(?:ction)?)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.export.ts"
            },
            "2": {
              "name": "keyword.other.pure.parabun"
            },
            "3": {
              "name": "storage.modifier.async.ts"
            },
            "4": {
              "name": "storage.type.function.ts"
            }
          }
        },
        {
          "comment": "export pure fun/function",
          "match": "\\b(export)\\s+(pure)\\s+(fun(?:ction)?)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.export.ts"
            },
            "2": {
              "name": "keyword.other.pure.parabun"
            },
            "3": {
              "name": "storage.type.function.ts"
            }
          }
        },
        {
          "comment": "pure async fun/function declaration/expression",
          "match": "\\b(pure)\\s+(async)\\s+(fun(?:ction)?)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.pure.parabun"
            },
            "2": {
              "name": "storage.modifier.async.ts"
            },
            "3": {
              "name": "storage.type.function.ts"
            }
          }
        },
        {
          "comment": "pure fun/function declaration/expression",
          "match": "\\b(pure)\\s+(fun(?:ction)?)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.pure.parabun"
            },
            "2": {
              "name": "storage.type.function.ts"
            }
          }
        },
        {
          "comment": "pure async arrow (before async keyword)",
          "match": "\\b(pure)\\s+(async)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
          "captures": {
            "1": {
              "name": "keyword.other.pure.parabun"
            },
            "2": {
              "name": "storage.modifier.async.ts"
            }
          }
        },
        {
          "comment": "pure arrow (before parens or identifier)",
          "match": "\\b(pure)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
          "captures": {
            "1": {
              "name": "keyword.other.pure.parabun"
            }
          }
        }
      ]
    },
    "parabun-operators": {
      "patterns": [
        {
          "comment": "..= inclusive-range operator",
          "name": "keyword.operator.range-inclusive.parabun",
          "match": "\\.\\.="
        },
        {
          "comment": "..! error catch operator",
          "name": "keyword.operator.catch.parabun",
          "match": "\\.\\.!"
        },
        {
          "comment": "..& finally operator",
          "name": "keyword.operator.finally.parabun",
          "match": "\\.\\.&"
        },
        {
          "comment": "..> then operator",
          "name": "keyword.operator.then.parabun",
          "match": "\\.\\.>"
        },
        {
          "comment": ".. exclusive-range operator (must come after ..= / ..! / ..& / ..>)",
          "name": "keyword.operator.range.parabun",
          "match": "\\.\\.(?!\\.)"
        },
        {
          "comment": "|> pipeline operator",
          "name": "keyword.operator.pipeline.parabun",
          "match": "\\|>"
        },
        {
          "comment": "~> reactive-binding operator",
          "name": "keyword.operator.rbind.parabun",
          "match": "~>"
        },
        {
          "comment": "-> reactive call-binding operator (negative lookbehind on -/=/< guards against -->/=>/<-)",
          "name": "keyword.operator.callbind.parabun",
          "match": "(?<![\\-=<])->"
        }
      ]
    },
    "parabun-parallel": {
      "patterns": [
        {
          "comment": "parallel/para let/const — statement form, fan-out promise composition",
          "match": "\\b(parallel|para)\\s+(let|const)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.parallel.parabun"
            },
            "2": {
              "name": "storage.type.ts"
            }
          }
        },
        {
          "comment": "parallel/para { … } — expression form, fan-out promise composition",
          "match": "\\b(parallel|para)\\b(?=\\s*\\{)",
          "captures": {
            "1": {
              "name": "keyword.other.parallel.parabun"
            }
          }
        }
      ]
    },
    "parabun-decimal-literal": {
      "patterns": [
        {
          "comment": "Nd decimal literal — base-10 number followed by `d` suffix",
          "match": "(?<![\\w$.])((?:\\.\\d+|\\d+(?:\\.\\d*)?)(?:[eE][+-]?\\d+)?)(d)(?![\\w$])",
          "captures": {
            "1": {
              "name": "constant.numeric.decimal.parabun"
            },
            "2": {
              "name": "keyword.other.suffix.decimal.parabun"
            }
          }
        }
      ]
    }
  }
}
