{
  "name": "parabun",
  "displayName": "Parabun",
  "description": "Language support for Parabun (.pts/.pjs) — Bun fork with pure functions, error chaining, pipelines, models, pattern matching, and runtime validation",
  "version": "0.11.23",
  "publisher": "parabun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/airgap/parabun.git",
    "directory": "editors/vscode/parabun"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:parabun-ts",
    "onLanguage:parabun-tsx",
    "onLanguage:parabun-js",
    "onLanguage:parabun-jsx",
    "onLanguage:parabun-ui",
    "onLanguage:svelte"
  ],
  "contributes": {
    "languages": [
      {
        "id": "parabun-ts",
        "aliases": [
          "Parabun TypeScript",
          "pts"
        ],
        "extensions": [
          ".pts"
        ],
        "icon": {
          "light": "./icons/pts.svg",
          "dark": "./icons/pts.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "parabun-tsx",
        "aliases": [
          "Parabun TSX",
          "ptsx"
        ],
        "extensions": [
          ".ptsx"
        ],
        "icon": {
          "light": "./icons/ptsx.svg",
          "dark": "./icons/ptsx.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "parabun-js",
        "aliases": [
          "Parabun JavaScript",
          "pjs"
        ],
        "extensions": [
          ".pjs"
        ],
        "icon": {
          "light": "./icons/pjs.svg",
          "dark": "./icons/pjs.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "parabun-jsx",
        "aliases": [
          "Parabun JSX",
          "pjsx"
        ],
        "extensions": [
          ".pjsx"
        ],
        "icon": {
          "light": "./icons/pjsx.svg",
          "dark": "./icons/pjsx.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "parabun-ui",
        "aliases": [
          "Parabun UI",
          "pui"
        ],
        "extensions": [
          ".pui"
        ],
        "icon": {
          "light": "./icons/pui.svg",
          "dark": "./icons/pui.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "parabun-ts",
        "scopeName": "source.pts",
        "path": "./syntaxes/parabun-ts.tmLanguage.json"
      },
      {
        "language": "parabun-tsx",
        "scopeName": "source.ptsx",
        "path": "./syntaxes/parabun-tsx.tmLanguage.json"
      },
      {
        "language": "parabun-js",
        "scopeName": "source.pjs",
        "path": "./syntaxes/parabun-js.tmLanguage.json"
      },
      {
        "language": "parabun-jsx",
        "scopeName": "source.pjsx",
        "path": "./syntaxes/parabun-jsx.tmLanguage.json"
      },
      {
        "language": "parabun-ui",
        "scopeName": "source.pui",
        "path": "./syntaxes/parabun-ui.tmLanguage.json",
        "embeddedLanguages": {
          "text.html.basic": "html",
          "text.html.markdown": "markdown",
          "text.pug": "jade",
          "source.css": "css",
          "source.css.less": "less",
          "source.css.scss": "scss",
          "source.css.postcss": "postcss",
          "source.sass": "sass",
          "source.stylus": "stylus",
          "source.js": "javascript",
          "source.ts": "typescript",
          "source.coffee": "coffeescript",
          "source.pts": "parabun-ts",
          "source.pjs": "parabun-js"
        },
        "unbalancedBracketScopes": [
          "keyword.operator.relational",
          "storage.type.function.arrow",
          "keyword.operator.bitwise.shift",
          "meta.brace.angle",
          "punctuation.definition.tag"
        ],
        "tokenTypes": {
          "punctuation.definition.template-expression": "other",
          "entity.name.type.instance.jsdoc": "other",
          "entity.name.function.tagged-template": "other",
          "meta.import string.quoted": "other",
          "variable.other.jsdoc": "other"
        }
      },
      {
        "scopeName": "inject.parabun-keywords",
        "path": "./syntaxes/parabun-inject.tmLanguage.json",
        "injectTo": [
          "source.pts",
          "source.ptsx",
          "source.pjs",
          "source.pjsx"
        ]
      },
      {
        "scopeName": "inject.parabun.pui.pts",
        "path": "./syntaxes/parabun-ui-inject.tmLanguage.json",
        "injectTo": [
          "source.svelte",
          "source.pui"
        ]
      },
      {
        "scopeName": "inject.parabun.pui.pjs",
        "path": "./syntaxes/parabun-ui-pjs-inject.tmLanguage.json",
        "injectTo": [
          "source.svelte",
          "source.pui"
        ]
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "parabun-ts",
        "scopes": {
          "function.pure": [
            "keyword.other.pure.parabun"
          ],
          "variable.signal": [
            "markup.italic variable.other.signal.parabun"
          ]
        }
      },
      {
        "language": "parabun-tsx",
        "scopes": {
          "function.pure": [
            "keyword.other.pure.parabun"
          ],
          "variable.signal": [
            "markup.italic variable.other.signal.parabun"
          ]
        }
      },
      {
        "language": "parabun-js",
        "scopes": {
          "function.pure": [
            "keyword.other.pure.parabun"
          ],
          "variable.signal": [
            "markup.italic variable.other.signal.parabun"
          ]
        }
      },
      {
        "language": "parabun-jsx",
        "scopes": {
          "function.pure": [
            "keyword.other.pure.parabun"
          ],
          "variable.signal": [
            "markup.italic variable.other.signal.parabun"
          ]
        }
      },
      {
        "language": "parabun-ui",
        "scopes": {
          "class": [
            "entity.name.tag",
            "entity.name.type.class",
            "support.class.component.svelte"
          ],
          "function.pure": [
            "keyword.other.pure.parabun"
          ],
          "variable.signal": [
            "markup.italic variable.other.signal.parabun"
          ]
        }
      }
    ],
    "snippets": [
      {
        "language": "parabun-ts",
        "path": "./snippets/parabun.json"
      },
      {
        "language": "parabun-tsx",
        "path": "./snippets/parabun.json"
      },
      {
        "language": "parabun-js",
        "path": "./snippets/parabun.json"
      },
      {
        "language": "parabun-jsx",
        "path": "./snippets/parabun.json"
      }
    ],
    "typescriptServerPlugins": [
      {
        "name": "parabun-ts-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ],
    "configuration": {
      "title": "Parabun",
      "properties": {
        "parabun.lsp.path": {
          "type": "string",
          "default": "parabun",
          "description": "Path to the parabun binary (used to run the LSP server)"
        }
      }
    },
    "configurationDefaults": {
      "[parabun-ui]": {
        "editor.semanticHighlighting.enabled": true
      },
      "[parabun-ts]": {
        "editor.semanticHighlighting.enabled": true
      },
      "[parabun-tsx]": {
        "editor.semanticHighlighting.enabled": true
      },
      "[parabun-js]": {
        "editor.semanticHighlighting.enabled": true
      },
      "[parabun-jsx]": {
        "editor.semanticHighlighting.enabled": true
      }
    }
  },
  "dependencies": {
    "sass": "^1.99.0",
    "typescript": "^5.0.0",
    "vscode-css-languageservice": "^6.3.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.js"
  }
}
