// Parabun macOS CI — builds the debug binary and runs the parabun test
// suite on a macOS agent via SSH dispatch, mirroring the lyku mac-mini
// pattern.
//
// The "mac-mini" host is an alias defined in the Jenkins controller's
// ~/.ssh/config (mounted read-only into this container). The SSH config
// contains the real hostname + user; nothing identifying lives here.
// The remote workspace is under the remote user's ~, so this file is
// safe to check into a public repo.
//
// Build prereqs installed once by hand on the mac agent: Xcode,
// homebrew, `brew install cmake ninja bun`.

pipeline {
    agent {
        docker {
            image 'ubuntu:24.04'
            label 'linux'
            args '--network host -v /var/lib/jenkins/.ssh:/tmp/.ssh-jenkins:ro'
        }
    }

    environment {
        CI = 'true'
        // rsync+ssh options: use the mounted jenkins ssh config, no host-key prompts.
        SSH_OPTS = '-F /tmp/.ssh-jenkins/config -o StrictHostKeyChecking=no -o UserKnownHostsFile=/tmp/.ssh-jenkins/known_hosts'
    }

    options {
        timestamps()
        ansiColor('xterm')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 60, unit: 'MINUTES')
    }

    parameters {
        booleanParam(name: 'RUN_TESTS', defaultValue: true, description: 'Run parabun test suite after build')
        string(name: 'TEST_FILTER', defaultValue: 'test/bundler/transpiler/parabun-*.test.js',
               description: 'Glob passed to `bun bd test`; default runs only parabun-* tests')
        booleanParam(name: 'PUBLISH_RELEASE', defaultValue: false,
                     description: 'Publish build/release/bun as a GitHub Release asset (parabun-macos-arm64-<sha>)')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.SHORT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    // We rsync with --exclude='.git', so the remote has no git
                    // metadata. scripts/build/config.ts::getGitRevision() would
                    // fall back to "unknown", which depVersionsHeader.ts filters
                    // out — making BUN_VERSION_UWS/USOCKETS undefined and
                    // breaking BunProcess.cpp compile. Resolve the sha here
                    // and forward it via env on the ssh commandline.
                    env.FULL_SHA = sh(script: 'git rev-parse HEAD', returnStdout: true).trim()
                    // Stable remote workspace under the mac user's $HOME. We
                    // keep a single tree so vendor/ (710MB of downloaded
                    // platform-specific deps) and build/ (incremental cache)
                    // survive across runs. rsync excludes preserve both.
                    env.REMOTE_WS = "jenkins/workspace/parabun"
                }
            }
        }

        stage('Install agent deps') {
            steps {
                // gh needed for the Publish release stage; pulled from the
                // GitHub CLI apt repo since ubuntu:24.04's archive is too old.
                sh '''
                    apt-get update -qq
                    apt-get install -y -qq --no-install-recommends rsync openssh-client git ca-certificates curl gnupg >/dev/null
                    if [ "${PUBLISH_RELEASE}" = "true" ]; then
                        install -m 0755 -d /etc/apt/keyrings
                        curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
                            | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg
                        chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
                        echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
                            > /etc/apt/sources.list.d/github-cli.list
                        apt-get update -qq
                        apt-get install -y -qq --no-install-recommends gh >/dev/null
                    fi
                '''
            }
        }

        stage('Sync to mac agent') {
            steps {
                // --delete keeps the remote tree clean; excludes trim what
                // the remote will regenerate or what we don't need.
                sh '''
                    rsync -az --delete \
                        -e "ssh ${SSH_OPTS}" \
                        --exclude='.git' \
                        --exclude='node_modules' \
                        --exclude='/build' \
                        --exclude='/vendor' \
                        --exclude='/target' \
                        --exclude='.claude' \
                        ./ mac-mini:${REMOTE_WS}/
                '''
            }
        }

        stage('Build on mac agent') {
            steps {
                sh '''
                    ssh ${SSH_OPTS} mac-mini "cd ${REMOTE_WS} && chmod +x jenkins/build-macos.sh && GIT_SHA=${FULL_SHA} ./jenkins/build-macos.sh"
                '''
            }
        }

        stage('Run parabun tests') {
            when { expression { params.RUN_TESTS } }
            steps {
                sh '''
                    ssh ${SSH_OPTS} mac-mini "cd ${REMOTE_WS} && ./build/debug/bun-debug test ${TEST_FILTER}"
                '''
            }
        }

        stage('Fetch artifacts') {
            steps {
                // Pull both debug and release binaries. Release comes over
                // only when PUBLISH_RELEASE is on; its absence is not a failure
                // for plain test runs.
                sh '''
                    mkdir -p artifacts/macos-arm64
                    rsync -az -e "ssh ${SSH_OPTS}" \
                        mac-mini:${REMOTE_WS}/build/debug/bun-debug \
                        artifacts/macos-arm64/ || true
                    if [ "${PUBLISH_RELEASE}" = "true" ]; then
                        rsync -az -e "ssh ${SSH_OPTS}" \
                            mac-mini:${REMOTE_WS}/build/release/bun \
                            artifacts/macos-arm64/
                    fi
                '''
            }
            post {
                success {
                    archiveArtifacts artifacts: 'artifacts/macos-arm64/*', allowEmptyArchive: true
                }
            }
        }

        stage('Publish release') {
            when { expression { params.PUBLISH_RELEASE } }
            steps {
                // GITHUB_TOKEN is a Jenkins "Secret text" credential scoped to
                // airgap/parabun with contents:write. The tag is SHA-derived so
                // reruns of the same commit are idempotent (we skip if the tag
                // already has the macos-arm64 asset attached).
                withCredentials([string(credentialsId: 'parabun-gh-token', variable: 'GITHUB_TOKEN')]) {
                    sh '''
                        set -eu
                        TAG="parabun-macos-arm64-${SHORT_SHA}"
                        ASSET="artifacts/macos-arm64/bun"
                        test -x "${ASSET}"

                        # Rename the asset to something recognizable on the releases page.
                        RENAMED="artifacts/macos-arm64/parabun-macos-arm64"
                        cp "${ASSET}" "${RENAMED}"

                        if gh release view "${TAG}" --repo airgap/parabun >/dev/null 2>&1; then
                            gh release upload "${TAG}" "${RENAMED}" --repo airgap/parabun --clobber
                        else
                            gh release create "${TAG}" "${RENAMED}" \
                                --repo airgap/parabun \
                                --target "${FULL_SHA}" \
                                --title "Parabun macOS arm64 @ ${SHORT_SHA}" \
                                --notes "Built by Jenkins on ${NODE_NAME} from ${FULL_SHA}."
                        fi
                    '''
                }
            }
        }
    }

    // NOTE: no post-cleanup — the remote workspace is stable so vendor/ and
    // build/ cache survive across runs. rsync --delete on the next invocation
    // handles stale source files.
}
