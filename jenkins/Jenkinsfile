// Parabun CI — builds release binaries for Linux x64, Linux aarch64,
// macOS arm64 and Windows x64 in parallel, optionally publishing all four
// as one tagged GitHub Release. Mirrors /raid/lyku/jenkins/Jenkinsfile.desktop's
// parallel-per-platform shape.
//
// Per-platform details:
//   - Linux x64:    builds in a container from jenkins/Dockerfile.ci-linux
//                   on any agent with the `linux` label (Built-In Node works).
//   - Linux arm64:  rsyncs source to the `parabun-jetson` SSH alias and
//                   invokes jenkins/build-linux-arm64.sh natively. Cross-
//                   compile from x86_64 is staged behind LYK-756 part 3
//                   (glibc-2.35 sysroot); until that ships, native build
//                   on the Jetson is the only path that produces binaries
//                   that run on Pi 5 / Jetson L4T.
//   - macOS:        rsyncs source to the `mac-mini` SSH alias and invokes
//                   jenkins/build-macos.sh there. The SSH alias is defined
//                   in the Jenkins controller's ~/.ssh/config (mounted
//                   read-only into the ubuntu:24.04 dispatcher container).
//   - Windows:      runs natively on the `windows` agent (windows-strix).
//                   See jenkins/setup-windows-agent.md for prereqs.
//
// Publishing uses the pre-existing `github-pat` credential (scoped to
// airgap/*, so no parabun-specific token needed). The release tag is
// `parabun-<short-sha>`; re-runs of the same commit clobber assets rather
// than creating duplicate tags.

pipeline {
    agent none

    environment {
        CI = 'true'
    }

    triggers {
        pollSCM('H/5 * * * *')
    }

    options {
        timestamps()
        ansiColor('xterm')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 120, unit: 'MINUTES')
    }

    parameters {
        booleanParam(name: 'BUILD_LINUX',         defaultValue: true,  description: 'Build Linux x64')
        booleanParam(name: 'BUILD_LINUX_ARM64',   defaultValue: false, description: 'Build Linux aarch64 (requires parabun-jetson SSH alias)')
        booleanParam(name: 'BUILD_MACOS',         defaultValue: true,  description: 'Build macOS arm64 (requires mac-mini agent)')
        booleanParam(name: 'BUILD_WINDOWS',       defaultValue: false, description: 'Build Windows x64 (requires windows agent)')
        booleanParam(name: 'BUILD_VSIX',    defaultValue: true,  description: 'Package the VS Code extension (.vsix)')
        booleanParam(name: 'RUN_TESTS',     defaultValue: true,  description: 'Run parabun test suite on macOS after build')
        string(name: 'TEST_FILTER', defaultValue: 'test/bundler/transpiler/parabun-*.test.js',
               description: 'Glob passed to `bun bd test`; default runs only parabun-* tests')
        booleanParam(name: 'PUBLISH_RELEASE', defaultValue: true,
                     description: 'Attach successful build/release binaries to a GitHub Release (parabun-<short-sha>)')
        booleanParam(name: 'PUBLISH_DOCKER', defaultValue: true,
                     description: 'Build & push Docker image to registry.digitalocean.com/parabun/parabun (:latest, :<short-sha>)')
        booleanParam(name: 'PUBLISH_NPM',    defaultValue: false,
                     description: 'Publish @lyku/para-signals + @lyku/para-ui + @lyku/para-preprocess to npm (--tag pre). Off by default — typical builds skip it; set true for explicit publish runs (you can also disable BUILD_* params for a publish-only fast path).')
    }

    stages {
        // Codegen / catalog-drift check moved to airgap/para with the
        // extraction (para owns `scripts/codegen.ts` + `codegen:check`
        // now). parabun no longer runs it — the script was git-rm'd here,
        // so calling it only red-failed CI on a check para already owns.
        stage('Build') {
            parallel {
                stage('Linux x64') {
                    when {
                        beforeAgent true
                        expression { params.BUILD_LINUX }
                    }
                    agent {
                        dockerfile {
                            filename 'jenkins/Dockerfile.ci-linux'
                            label 'linux'
                            // First run on a node builds the image (~5 min);
                            // subsequent runs reuse the BuildKit layer cache.
                            additionalBuildArgs '--pull'
                            // The controller's / partition (~500GB, shared
                            // with crossdraw artifacts + lyku workspaces +
                            // docker) can't fit a Parabun release build,
                            // whose zig ReleaseFast step peaks at ~20GB of
                            // intermediates. /raid has 99GB free on its
                            // own partition.
                            customWorkspace '/raid/jenkins-workspaces/parabun'
                        }
                    }
                    steps {
                        checkout scm
                        script {
                            env.FULL_SHA  = sh(script: 'git rev-parse HEAD', returnStdout: true).trim()
                            env.SHORT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                        }
                        sh '''
                            chmod +x jenkins/build-linux.sh
                            GIT_SHA=${FULL_SHA} ./jenkins/build-linux.sh
                        '''
                        sh '''
                            mkdir -p artifacts
                            cp build/release/bun artifacts/parabun-linux-x64
                        '''
                        stash name: 'linux-bin', includes: 'artifacts/parabun-linux-x64'
                    }
                    post {
                        success {
                            archiveArtifacts artifacts: 'artifacts/parabun-linux-x64', allowEmptyArchive: true
                        }
                    }
                }

                stage('Linux aarch64') {
                    when {
                        beforeAgent true
                        expression { params.BUILD_LINUX_ARM64 }
                    }
                    // Dispatched from the Jenkins controller (built-in node)
                    // — the Jetson agent is reached over SSH, not as a
                    // first-class Jenkins agent. Same shape as the macOS
                    // stage to keep the cross-platform pattern symmetric:
                    // rsync source out, build there, rsync binary back.
                    agent { label 'built-in' }
                    environment {
                        // Stable remote workspace under the agent user's
                        // $HOME on the Jetson. Single tree so vendor/
                        // (~700 MB of platform deps) and build/ (incremental
                        // cache) survive across runs. rsync --exclude
                        // preserves both.
                        REMOTE_WS = 'jenkins/workspace/parabun'
                        // SSH alias for the arm64 build agent. Configured
                        // in the controller's ~/.ssh/config; the user
                        // points this at whichever board they want to
                        // build on (Jetson Orin Nano: ~30-60 min;
                        // Pi 5: ~2 hr).
                        REMOTE_HOST = 'parabun-jetson'
                    }
                    steps {
                        checkout scm
                        script {
                            env.FULL_SHA  = sh(script: 'git rev-parse HEAD', returnStdout: true).trim()
                            env.SHORT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                        }
                        sh '''
                            rsync -az --delete \
                                --exclude='.git' \
                                --exclude='node_modules' \
                                --exclude='/build' \
                                --exclude='/vendor' \
                                --exclude='/target' \
                                --exclude='.claude' \
                                ./ ${REMOTE_HOST}:${REMOTE_WS}/
                        '''
                        // The remote has no .git (rsync excludes it), so
                        // scripts/build/config.ts::getGitRevision() would
                        // fall back to "unknown", breaking BunProcess.cpp.
                        // Forward FULL_SHA as GIT_SHA env instead — same
                        // pattern the macOS stage uses.
                        sh '''
                            ssh ${REMOTE_HOST} "cd ${REMOTE_WS} && chmod +x jenkins/build-linux-arm64.sh && GIT_SHA=${FULL_SHA} ./jenkins/build-linux-arm64.sh"
                        '''
                        sh '''
                            mkdir -p artifacts
                            rsync -az \
                                ${REMOTE_HOST}:${REMOTE_WS}/build/release/bun \
                                artifacts/parabun-linux-aarch64
                        '''
                        stash name: 'linux-arm64-bin', includes: 'artifacts/parabun-linux-aarch64'
                    }
                    post {
                        success {
                            archiveArtifacts artifacts: 'artifacts/parabun-linux-aarch64', allowEmptyArchive: true
                        }
                    }
                }

                stage('macOS arm64') {
                    when {
                        beforeAgent true
                        expression { params.BUILD_MACOS }
                    }
                    // Runs natively on the Jenkins controller (built-in node)
                    // rather than in a docker dispatcher. The controller
                    // already has git, rsync, ssh, and the mac-mini alias in
                    // ~/.ssh/config, so no container gymnastics are needed.
                    agent { label 'built-in' }
                    environment {
                        // Stable remote workspace under the mac user's $HOME.
                        // Single tree so vendor/ (710MB of downloaded platform
                        // deps) and build/ (incremental cache) survive across
                        // runs. rsync --exclude preserves both.
                        REMOTE_WS = 'jenkins/workspace/parabun'
                    }
                    steps {
                        checkout scm
                        script {
                            env.FULL_SHA  = sh(script: 'git rev-parse HEAD', returnStdout: true).trim()
                            env.SHORT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                        }
                        sh '''
                            rsync -az --delete \
                                --exclude='.git' \
                                --exclude='node_modules' \
                                --exclude='/build' \
                                --exclude='/vendor' \
                                --exclude='/target' \
                                --exclude='.claude' \
                                ./ mac-mini:${REMOTE_WS}/
                        '''
                        // The remote has no .git (rsync excludes it), so
                        // scripts/build/config.ts::getGitRevision() would
                        // fall back to "unknown", breaking BunProcess.cpp.
                        // Forward FULL_SHA as GIT_SHA env instead.
                        sh '''
                            ssh mac-mini "cd ${REMOTE_WS} && chmod +x jenkins/build-macos.sh && GIT_SHA=${FULL_SHA} ./jenkins/build-macos.sh"
                        '''
                        script {
                            if (params.RUN_TESTS) {
                                sh '''
                                    ssh mac-mini "cd ${REMOTE_WS} && ./build/release/bun test ${TEST_FILTER}"
                                '''
                            }
                        }
                        sh '''
                            mkdir -p artifacts
                            rsync -az \
                                mac-mini:${REMOTE_WS}/build/release/bun \
                                artifacts/parabun-macos-arm64
                        '''
                        stash name: 'macos-bin', includes: 'artifacts/parabun-macos-arm64'
                    }
                    post {
                        success {
                            archiveArtifacts artifacts: 'artifacts/parabun-macos-arm64', allowEmptyArchive: true
                        }
                    }
                }

                stage('Windows x64') {
                    when {
                        beforeAgent true
                        expression { params.BUILD_WINDOWS }
                    }
                    agent { label 'windows' }
                    steps {
                        checkout scm
                        script {
                            env.FULL_SHA  = bat(script: '@git rev-parse HEAD', returnStdout: true).trim()
                            env.SHORT_SHA = bat(script: '@git rev-parse --short HEAD', returnStdout: true).trim()
                        }
                        powershell '''
                            $env:GIT_SHA = $env:FULL_SHA
                            .\\jenkins\\build-windows.ps1
                        '''
                        powershell '''
                            New-Item -ItemType Directory -Force -Path artifacts | Out-Null
                            Copy-Item build\\release\\bun.exe artifacts\\parabun-windows-x64.exe
                        '''
                        stash name: 'windows-bin', includes: 'artifacts/parabun-windows-x64.exe'
                    }
                    post {
                        success {
                            archiveArtifacts artifacts: 'artifacts/parabun-windows-x64.exe', allowEmptyArchive: true
                        }
                    }
                }

                stage('VSIX') {
                    when {
                        beforeAgent true
                        expression { params.BUILD_VSIX }
                    }
                    // Uses the same Linux CI image; node + npm are already
                    // installed for Parabun's own build scripts, and @vscode/vsce
                    // is fetched on-demand via npx.
                    agent {
                        dockerfile {
                            filename 'jenkins/Dockerfile.ci-linux'
                            label 'linux'
                            additionalBuildArgs '--pull'
                            customWorkspace '/raid/jenkins-workspaces/parabun-vsix'
                        }
                    }
                    steps {
                        checkout scm
                        sh '''
                            set -eu
                            # Container runs as the host jenkins UID (132), which
                            # has no $HOME. Point npm/npx caches at the workspace
                            # so they don't try to mkdir /.npm.
                            export HOME="${WORKSPACE}"
                            export npm_config_cache="${WORKSPACE}/.npm"
                            mkdir -p "${npm_config_cache}"
                            # The CI image doesn't ship a parabun binary on PATH —
                            # the matched binary is published as a separate
                            # artifact by the build stages. copy-assets.js has a
                            # PATH check meant to catch local devs packaging a
                            # debug build; we bypass it explicitly here.
                            export PARABUN_VSIX_SKIP_BINARY_CHECK=1
                            # Build the TS plugin first — copy-assets.js
                            # copies its output into the VSIX.
                            cd editors/ts-plugin
                            npm install --ignore-scripts --no-audit --no-fund
                            npm run build
                            # LSP pui-transform deps — copy-assets.js execs
                            # editors/lsp/esbuild-pui-transform.mjs, which
                            # needs svelte2tsx/svelte/trace-mapping/preprocess.
                            cd ../lsp
                            npm install --ignore-scripts --no-audit --no-fund
                            cd ../vscode/parabun
                            # package-lock.json is gitignored — any lockfile
                            # in the workspace is a leftover from a previous
                            # run, not a committed source of truth. `npm ci`
                            # would refuse to reconcile a package.json dep
                            # bump against it (npm error "missing from lock
                            # file"), so always do `npm install` and let it
                            # rewrite the lockfile in place.
                            npm install --ignore-scripts --no-audit --no-fund
                            npm run build
                            # Extension imports vscode-languageclient at runtime,
                            # so node_modules needs to ride along. .vscodeignore
                            # allowlists only the runtime dep + its transitives.
                            mkdir -p ../../../artifacts
                            npx --yes @vscode/vsce@^3 package \
                                --out ../../../artifacts/parabun.vsix
                        '''
                        stash name: 'vsix-bin', includes: 'artifacts/parabun.vsix'
                    }
                    post {
                        success {
                            archiveArtifacts artifacts: 'artifacts/parabun.vsix', allowEmptyArchive: true
                        }
                    }
                }
            }
        }

        stage('Publish release') {
            when { expression { params.PUBLISH_RELEASE } }
            // Reuses the Linux CI image since it already has git + gh baked
            // in. No additional setup needed beyond unstashing artifacts.
            agent {
                dockerfile {
                    filename 'jenkins/Dockerfile.ci-linux'
                    label 'linux'
                    customWorkspace '/raid/jenkins-workspaces/parabun-publish'
                }
            }
            steps {
                checkout scm
                script {
                    env.FULL_SHA  = sh(script: 'git rev-parse HEAD', returnStdout: true).trim()
                    env.SHORT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                }
                script {
                    if (params.BUILD_LINUX)       { unstash 'linux-bin' }
                    if (params.BUILD_LINUX_ARM64) { unstash 'linux-arm64-bin' }
                    if (params.BUILD_MACOS)       { unstash 'macos-bin' }
                    if (params.BUILD_WINDOWS)     { unstash 'windows-bin' }
                    if (params.BUILD_VSIX)        { unstash 'vsix-bin' }
                }
                // github-pat is a "Username with password" credential; gh
                // honors GH_TOKEN from the environment.
                withCredentials([usernamePassword(
                    credentialsId: 'github-pat',
                    usernameVariable: 'GH_USER',
                    passwordVariable: 'GH_TOKEN',
                )]) {
                    sh '''
                        set -eu
                        TAG="parabun-${SHORT_SHA}"
                        ASSETS=$(ls artifacts/parabun* 2>/dev/null || true)
                        test -n "${ASSETS}" || { echo "no artifacts to publish"; exit 1; }
                        echo "Uploading to ${TAG}:"
                        printf '  %s\\n' ${ASSETS}

                        if gh release view "${TAG}" --repo airgap/parabun >/dev/null 2>&1; then
                            gh release upload "${TAG}" ${ASSETS} --repo airgap/parabun --clobber
                        else
                            gh release create "${TAG}" ${ASSETS} \
                                --repo airgap/parabun \
                                --target "${FULL_SHA}" \
                                --title "Parabun @ ${SHORT_SHA}" \
                                --notes "Built by Jenkins from ${FULL_SHA}."
                        fi
                    '''
                }
            }
        }

        stage('Publish Docker') {
            // Requires the Linux build — we COPY the artifact into the image
            // rather than curl-ing it from a release, so no Linux binary = no
            // image to push. linux/amd64 only; add arm64 once an arm builder
            // exists.
            when {
                expression { params.PUBLISH_DOCKER && params.BUILD_LINUX }
            }
            // Runs on the Jenkins controller, which already has docker (it
            // builds the ci-linux dockerfile agent) and mounts
            // /etc/default/jenkins-doppler. Mirrors the lyku workers pipeline's
            // Doppler → DIGITALOCEAN_ACCESS_TOKEN path.
            agent { label 'built-in' }
            steps {
                script {
                    env.SHORT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                }
                unstash 'linux-bin'
                sh '''
                    set -eu
                    install -m 0755 artifacts/parabun-linux-x64 dockerhub/parabun/bun
                '''
                sh '''
                    set -eu
                    set +x
                    export DOPPLER_TOKEN=$(grep DOPPLER_TOKEN_CI_DEPLOY /etc/default/jenkins-doppler | cut -d= -f2)
                    TEMP_HOME=$(mktemp -d)
                    DO_TOKEN=$(HOME=$TEMP_HOME doppler secrets get DIGITALOCEAN_ACCESS_TOKEN --plain --project ci-deploy --config prd)
                    rm -rf "$TEMP_HOME"
                    echo "$DO_TOKEN" | docker login registry.digitalocean.com -u do --password-stdin
                    set -x

                    REGISTRY=registry.digitalocean.com/parabun
                    docker build \
                        -t "${REGISTRY}/parabun:latest" \
                        -t "${REGISTRY}/parabun:${SHORT_SHA}" \
                        dockerhub/parabun
                    docker push "${REGISTRY}/parabun:latest"
                    docker push "${REGISTRY}/parabun:${SHORT_SHA}"
                '''
            }
            post {
                always {
                    // Don't leave a stale binary in the build context if the
                    // workspace gets reused. docker logout also clears the
                    // token from ~/.docker/config.json on the controller.
                    sh '''
                        rm -f dockerhub/parabun/bun
                        docker logout registry.digitalocean.com >/dev/null 2>&1 || true
                    '''
                }
            }
        }

        // npm publish: ships @lyku/para-signals + @lyku/para-ui under --tag pre
        // so consumers opt in via `bun add @lyku/para-ui@pre`. Uses the same
        // Doppler NPM_ACCESS_TOKEN (ci-deploy/prd) lyku-npm-publish reads.
        //
        // Designed for two trigger modes:
        //   - Full release run: BUILD_* + PUBLISH_RELEASE + PUBLISH_DOCKER + PUBLISH_NPM
        //   - Publish-only fast path: BUILD_* all off, RUN_TESTS off,
        //     PUBLISH_RELEASE off, PUBLISH_DOCKER off, PUBLISH_NPM on.
        //     Skips the build matrix entirely.
        //
        // The @lyku/para-ui stage sed-swaps the local-dev `file:` dep on
        // @lyku/para-signals to a real semver before publish, reverts in
        // `post.always` so the file: dep stays intact for local dev.
        stage('Publish npm') {
            when { expression { params.PUBLISH_NPM } }
            agent {
                dockerfile {
                    filename 'jenkins/Dockerfile.ci-linux'
                    label 'linux'
                    customWorkspace '/raid/jenkins-workspaces/parabun-npm-publish'
                    args '-v /etc/default/jenkins-doppler:/etc/default/jenkins-doppler:ro'
                }
            }
            steps {
                checkout scm
                script {
                    env.SHORT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                }
                sh '''
                    set -eu
                    set +x
                    # The docker container's jenkins user has no $HOME by default.
                    # Point HOME at the workspace so .npmrc + doppler temp dirs land somewhere writable.
                    export HOME="${WORKSPACE}"
                    export DOPPLER_TOKEN=$(grep DOPPLER_TOKEN_CI_DEPLOY /etc/default/jenkins-doppler | cut -d= -f2)
                    NPM_TOKEN=$(doppler secrets get NPM_ACCESS_TOKEN --plain --project ci-deploy --config prd)
                    echo "//registry.npmjs.org/:_authToken=$NPM_TOKEN" > "$HOME/.npmrc"
                    echo "auth ok: $(npm whoami)"
                '''
                // @lyku/para-signals first — @lyku/para-ui depends on it.
                // Idempotent: if the version is already on npm, skip the publish
                // rather than failing (lets re-runs proceed to @lyku/para-ui).
                sh '''
                    set -eu
                    export HOME="${WORKSPACE}"
                    cd packages/para-signals
                    PKG_VERSION=$(node -p "require('./package.json').version")
                    if npm view "@lyku/para-signals@$PKG_VERSION" version >/dev/null 2>&1; then
                        echo "@lyku/para-signals@$PKG_VERSION already published, skipping"
                    else
                        npm publish --tag pre
                    fi
                '''
                // @lyku/para-ui — needs a build + the file:-dep swap dance.
                sh '''
                    set -eu
                    export HOME="${WORKSPACE}"
                    cd packages/para-svelte/packages/svelte
                    PKG_VERSION=$(node -p "require('./package.json').version")
                    if npm view "@lyku/para-ui@$PKG_VERSION" version >/dev/null 2>&1; then
                        echo "@lyku/para-ui@$PKG_VERSION already published, skipping"
                        exit 0
                    fi
                    SIGNALS_VERSION="^$(node -p "require('../../../para-signals/package.json').version")"
                    sed -i 's|"@lyku/para-signals": "file:[^"]*"|"@lyku/para-signals": "'"$SIGNALS_VERSION"'"|' package.json
                    pnpm install --frozen-lockfile=false
                    pnpm run build
                    npm publish --tag pre
                '''
                // @lyku/para-preprocess — tsc build then publish. Same idempotence.
                // bun-types is a workspace dep at parabun root; install from
                // root (not from the package subdir) so tsc finds it.
                sh '''
                    set -eu
                    export HOME="${WORKSPACE}"
                    PKG_VERSION=$(node -p "require('./packages/para-preprocess/package.json').version")
                    if npm view "@lyku/para-preprocess@$PKG_VERSION" version >/dev/null 2>&1; then
                        echo "@lyku/para-preprocess@$PKG_VERSION already published, skipping"
                        exit 0
                    fi
                    bun install --ignore-scripts --no-audit --no-fund
                    cd packages/para-preprocess
                    bun run build
                    npm publish --tag pre
                '''
            }
            post {
                always {
                    sh '''
                        export HOME="${WORKSPACE}"
                        # Revert the file: dep swap so local dev stays intact.
                        cd packages/para-svelte/packages/svelte
                        git checkout package.json || true
                        # Don't leak the token.
                        rm -f "$HOME/.npmrc" || true
                    '''
                }
            }
        }
    }
}
