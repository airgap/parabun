{
  "name": "parabun",
  "displayName": "Parabun",
  "description": "Language support for Parabun (.pts/.pjs) — Bun fork with pure functions, error chaining, pipelines, models, pattern matching, and runtime validation",
  "version": "0.11.6",
  "publisher": "parabun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/airgap/parabun.git",
    "directory": "editors/vscode/parabun"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:parabun-ts",
    "onLanguage:parabun-tsx",
    "onLanguage:parabun-js",
    "onLanguage:parabun-jsx"
  ],
  "contributes": {
    "languages": [
      {
        "id": "parabun-ts",
        "aliases": [
          "Parabun TypeScript",
          "pts"
        ],
        "extensions": [
          ".pts"
        ],
        "icon": {
          "light": "./icons/pts.svg",
          "dark": "./icons/pts.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "parabun-tsx",
        "aliases": [
          "Parabun TSX",
          "ptsx"
        ],
        "extensions": [
          ".ptsx"
        ],
        "icon": {
          "light": "./icons/ptsx.svg",
          "dark": "./icons/ptsx.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "parabun-js",
        "aliases": [
          "Parabun JavaScript",
          "pjs"
        ],
        "extensions": [
          ".pjs"
        ],
        "icon": {
          "light": "./icons/pjs.svg",
          "dark": "./icons/pjs.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "parabun-jsx",
        "aliases": [
          "Parabun JSX",
          "pjsx"
        ],
        "extensions": [
          ".pjsx"
        ],
        "icon": {
          "light": "./icons/pjsx.svg",
          "dark": "./icons/pjsx.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "parabun-ts",
        "scopeName": "source.pts",
        "path": "./syntaxes/parabun-ts.tmLanguage.json"
      },
      {
        "language": "parabun-tsx",
        "scopeName": "source.ptsx",
        "path": "./syntaxes/parabun-tsx.tmLanguage.json"
      },
      {
        "language": "parabun-js",
        "scopeName": "source.pjs",
        "path": "./syntaxes/parabun-js.tmLanguage.json"
      },
      {
        "language": "parabun-jsx",
        "scopeName": "source.pjsx",
        "path": "./syntaxes/parabun-jsx.tmLanguage.json"
      },
      {
        "scopeName": "inject.parabun-keywords",
        "path": "./syntaxes/parabun-inject.tmLanguage.json",
        "injectTo": [
          "source.pts",
          "source.ptsx",
          "source.pjs",
          "source.pjsx"
        ]
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "parabun-ts",
        "scopes": {
          "function.pure": [
            "keyword.other.pure.parabun"
          ],
          "variable.signal": [
            "markup.italic variable.other.signal.parabun"
          ]
        }
      },
      {
        "language": "parabun-tsx",
        "scopes": {
          "function.pure": [
            "keyword.other.pure.parabun"
          ],
          "variable.signal": [
            "markup.italic variable.other.signal.parabun"
          ]
        }
      },
      {
        "language": "parabun-js",
        "scopes": {
          "function.pure": [
            "keyword.other.pure.parabun"
          ],
          "variable.signal": [
            "markup.italic variable.other.signal.parabun"
          ]
        }
      },
      {
        "language": "parabun-jsx",
        "scopes": {
          "function.pure": [
            "keyword.other.pure.parabun"
          ],
          "variable.signal": [
            "markup.italic variable.other.signal.parabun"
          ]
        }
      }
    ],
    "snippets": [
      {
        "language": "parabun-ts",
        "path": "./snippets/parabun.json"
      },
      {
        "language": "parabun-tsx",
        "path": "./snippets/parabun.json"
      },
      {
        "language": "parabun-js",
        "path": "./snippets/parabun.json"
      },
      {
        "language": "parabun-jsx",
        "path": "./snippets/parabun.json"
      }
    ],
    "typescriptServerPlugins": [
      {
        "name": "parabun-ts-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ],
    "configuration": {
      "title": "Parabun",
      "properties": {
        "parabun.lsp.path": {
          "type": "string",
          "default": "parabun",
          "description": "Path to the parabun binary (used to run the LSP server)"
        }
      }
    }
  },
  "dependencies": {
    "typescript": "^5.0.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.js"
  }
}
