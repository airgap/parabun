// Reactive button → LED — the simplest IoT shape in parabun.
//
//   bun run build:release demos/iot-button-led.pts [--seconds N]
//
// Wire BCM 27 → button to ground (pull-up), BCM 17 → LED. The whole
// control loop is one reactive call-binding: when `button.value`
// changes, `led.write` is re-called with the new value. The `->`
// operator desugars to `effect(() => led.write(...))` — every signal
// read on the LHS is tracked automatically.
//
// `pollHz: 50` tells `bun:gpio` to drive `button.value` at 50 Hz in the
// background — no manual `setInterval`, no separate read loop. (Once
// `line.edges()` moves off the JS main thread (LYK-786), `edge: "..."`
// will drive the signal at hardware-event latency and pollHz becomes
// optional.)

import gpio from "bun:gpio";

const args = process.argv.slice(2);
const sIdx = args.indexOf("--seconds");
const seconds = sIdx >= 0 ? Number(args[sIdx + 1]) : null;

const chips = gpio.chips();
const rp1 = chips.find(c => c.label === "pinctrl-rp1");
const chipPath = process.env.GPIO_CHIP ?? rp1?.path ?? chips[0]?.path;
if (!chipPath) {
  console.error("no /dev/gpiochip* found — bun:gpio is Linux-only.");
  process.exit(1);
}

await using chip = gpio.open(chipPath);
await using button = chip.line(27, { mode: "in", pull: "up", debounceMs: 5, pollHz: 50 });
await using led = chip.line(17, { mode: "out", initial: 0 });

// The whole control loop. Pull-up: button reads 0 when pressed, 1 when
// released; `->` mirrors that inverted into the LED on every change.
(button.value.get() === 0 ? 1 : 0) -> led.write;

console.log("button BCM27 → LED BCM17. Press the button to light the LED.");
if (seconds !== null && Number.isFinite(seconds)) {
  console.log(`(non-interactive: stopping in ${seconds}s)`);
  await Bun.sleep(seconds * 1000);
} else {
  console.log("Ctrl-C to stop.");
  await new Promise(() => {});
}

led.write(0);
console.log("done.");
