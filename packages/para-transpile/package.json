{
  "name": "@para/transpile",
  "version": "0.0.0-dev",
  "private": true,
  "description": "Standalone transpiler for Para (.pts) — turns Para source into standard JavaScript that runs anywhere via parabun-browser-shims. No Parabun runtime required. NOT YET RELEASED — `private: true` and `0.0.0-dev` until every desugaring lands.",
  "repository": {
    "type": "git",
    "url": "https://github.com/airgap/parabun",
    "directory": "packages/para-transpile"
  },
  "license": "MIT",
  "type": "module",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "para": "./dist/cli.js"
  },
  "scripts": {
    "check:types": "tsc --noEmit",
    "build": "tsc",
    "test": "USE_SYSTEM_BUN=1 bun test",
    "parity": "USE_SYSTEM_BUN=1 bun test/parity/runner.ts"
  },
  "devDependencies": {
    "@types/bun": "*",
    "typescript": "^5.0.0"
  },
  "files": [
    "README.md",
    "src",
    "dist"
  ],
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0"
  }
}
