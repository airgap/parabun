{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Parabun TSX",
  "scopeName": "source.ptsx",
  "patterns": [{ "include": "#parabun-pure" }, { "include": "#parabun-operators" }, { "include": "source.tsx" }],
  "repository": {
    "parabun-pure": {
      "patterns": [
        {
          "match": "\\b(pure)\\s+(async)\\s+(function)\\b",
          "captures": {
            "1": { "name": "storage.modifier.pure.parabun" },
            "2": { "name": "storage.modifier.async.tsx" },
            "3": { "name": "storage.type.function.tsx" }
          }
        },
        {
          "match": "\\b(pure)\\s+(function)\\b",
          "captures": {
            "1": { "name": "storage.modifier.pure.parabun" },
            "2": { "name": "storage.type.function.tsx" }
          }
        },
        {
          "match": "\\b(pure)\\s+(async)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
          "captures": {
            "1": { "name": "storage.modifier.pure.parabun" },
            "2": { "name": "storage.modifier.async.tsx" }
          }
        },
        {
          "match": "\\b(pure)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
          "captures": {
            "1": { "name": "storage.modifier.pure.parabun" }
          }
        }
      ]
    },
    "parabun-operators": {
      "patterns": [
        {
          "name": "keyword.operator.await-assign.parabun",
          "match": "\\.\\.="
        },
        {
          "name": "keyword.operator.catch.parabun",
          "match": "\\.\\.!"
        },
        {
          "name": "keyword.operator.finally.parabun",
          "match": "\\.\\.&"
        },
        {
          "name": "keyword.operator.pipeline.parabun",
          "match": "\\|>"
        }
      ]
    }
  }
}
