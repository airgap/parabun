{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Parabun Keyword Injection",
  "scopeName": "inject.parabun-keywords",
  "injectionSelector": "L:source.pts, L:source.ptsx, L:source.pjs, L:source.pjsx",
  "patterns": [
    {
      "match": "\\b(fun)\\b(?=\\s*[a-zA-Z_$*(<])",
      "captures": {
        "1": { "name": "storage.type.function.parabun" }
      }
    },
    {
      "match": "\\b(pure)\\s+(async)\\s+(fun(?:ction)?)\\b",
      "captures": {
        "1": { "name": "keyword.other.pure.parabun" },
        "2": { "name": "storage.modifier.async" },
        "3": { "name": "storage.type.function.parabun" }
      }
    },
    {
      "match": "\\b(pure)\\s+(fun(?:ction)?)\\b",
      "captures": {
        "1": { "name": "keyword.other.pure.parabun" },
        "2": { "name": "storage.type.function.parabun" }
      }
    },
    {
      "match": "\\b(pure)\\s+(async)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
      "captures": {
        "1": { "name": "keyword.other.pure.parabun" },
        "2": { "name": "storage.modifier.async" }
      }
    },
    {
      "match": "\\b(pure)\\b(?=\\s*(?:\\(|\\w+\\s*=>))",
      "captures": {
        "1": { "name": "keyword.other.pure.parabun" }
      }
    },
    {
      "match": "\\b(signal)\\b(?=\\s+[A-Za-z_$][\\w$]*\\s*[=,;:!])",
      "captures": {
        "1": { "name": "storage.type.signal.parabun" }
      }
    },
    {
      "match": "\\b(effect)\\b(?=\\s*\\{)",
      "captures": {
        "1": { "name": "keyword.control.effect.parabun" }
      }
    },
    {
      "match": "\\b(arena)\\b(?=\\s*\\{)",
      "captures": {
        "1": { "name": "keyword.control.arena.parabun" }
      }
    },
    {
      "match": "\\b(memo)\\s+(async)\\s+(?=[A-Za-z_$][\\w$]*\\s*(?:<|\\())",
      "captures": {
        "1": { "name": "keyword.other.memo.parabun" },
        "2": { "name": "storage.modifier.async" }
      }
    },
    {
      "match": "\\b(memo)\\s+(?=[A-Za-z_$][\\w$]*\\s*(?:<|\\())",
      "captures": {
        "1": { "name": "keyword.other.memo.parabun" }
      }
    },
    {
      "match": "\\b(defer|async\\s+defer)\\b(?=\\s+[A-Za-z_$])",
      "captures": {
        "1": { "name": "keyword.control.defer.parabun" }
      }
    },
    {
      "match": "~>",
      "name": "keyword.operator.rbind.parabun"
    }
  ]
}
